# ============================================================
#  VIETNEW ENTERTAINMENT - Zalo Bot Configuration
#  Copy file này thành .env và điền thông tin cấu hình
# ============================================================

# ---- Zalo Bot ----
BOT_TOKEN=your_bot_token_here
WEBHOOK_SECRET_TOKEN=your_webhook_secret_here

# ---- AI Agent ----
AI_PROXY_URL=http://your-ai-proxy:port/
AI_API_KEY=your_api_key_here
AI_MODEL=gpt-5.3-codex

# ---- Server ----
PORT=8888
NODE_ENV=production

# ---- Authentication ----
# Zalo User ID của Admin (lấy bằng cách nhắn /id cho Bot)
ADMIN_ZALO_ID=your_admin_zalo_id_here
# Secret key cho session (tạo random string dài)
SESSION_SECRET=your_session_secret_here_change_this

# ---- Branding ----
COMPANY_NAME=VIETNEW ENTERTAINMENT
PRIMARY_COLOR=#00582a

# ---- Public URL ----
# URL công khai của bot (dùng cho login link gửi qua Zalo)
# Bắt buộc khi deploy VPS, nếu thiếu sẽ dùng localhost
BASE_URL=https://bot.yourdomain.com
